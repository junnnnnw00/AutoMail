<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.junwoo.mailsorter.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/MailSorter.app/Contents/MacOS/MailSorterDaemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>ProcessType</key>
    <string>Background</string>
    <key>StandardOutPath</key>
    <string>/Users/USER/Library/Logs/MailSorter/daemon.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/USER/Library/Logs/MailSorter/daemon.err</string>
</dict>
</plist>
